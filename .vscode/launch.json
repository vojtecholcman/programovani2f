            "mainClass": "${file}",
            "vmArgs": "--module-path ${workspaceFolder}/../javafx-sdk-21.0.7/lib --add-modules javafx.controls,javafx.fxml,javafx.swing,javafx.media,javafx.web"
        }
    ]
}
